# ═══════════════════════════════════════════════════════════
# PS Gestão ERP — Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha os valores.
# NUNCA commite o .env.local no Git.
# ═══════════════════════════════════════════════════════════

# ── Supabase (Projeto > Settings > API) ──────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Anthropic (console.anthropic.com) ────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Deploy Webhook (gere uma string aleatória segura) ─────────
# Exemplo: openssl rand -hex 32
DEPLOY_SECRET_TOKEN=sua_chave_secreta_aqui_minimo_32_chars

# ── Ambiente ──────────────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── (Produção) ────────────────────────────────────────────────
# NEXT_PUBLIC_APP_URL=https://erp-psgestao.vercel.app
